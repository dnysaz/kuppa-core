class {{name}} extends BaseController {

    /**
     * [GET] Index Page
     */
    async index(process) {
        const title       = 'List of {{name}}';
        const description = 'Manage your {{name_lower}} here.';
        const view        = '{{name_lower}}.index';

        return process.view(view).with({ 
            title,
            description
        });
    }

    /**
     * [GET] Create Page
     */
    async create(process) {
        const title = 'Create New {{name}}';
        const view  = '{{name_lower}}.create';

        return process.view(view).with({ 
            title 
        });
    }

    /**
     * [POST] Store Action
     */
    async store(process) {
        // Example: logic to save data
        // await Model.create(process.body);

        process.res.flash('success', 'Data created successfully!');
        return process.res.redirect('back');
    }

    /**
     * [GET] Edit Page
     */
    async edit(process) {
        const { id } = process.req.params;
        const title  = 'Edit {{name}}';
        
        return process.view('{{name_lower}}.edit').with({ 
            title,
            id 
        });
    }
}

// Export as Instance for Route Config
module.exports = new {{name}}();
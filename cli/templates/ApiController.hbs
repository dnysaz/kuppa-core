/**
 * {{name}} - Kuppa API Framework
 * Standardized JSON CRUD Operations
 * Async-Instance Pattern by Ketut Dana
 */

// Core & Application Dependencies
const BaseController = coreFile('controller.BaseController');
const Model          = appFile('Models.Model'); 

class {{name}} extends BaseController {

    /**
     * [GET] List all resources
     */
    async index(process) {
        const Model = process.Model;

        // Guard: Autentikasi
        if (!user) {
            return process.json({
                status: 'error',
                message: 'Unauthorized: User session not found'
            }, 401);
        }

        try {
            const message = '{{name}} list retrieved successfully';
            const data    = await Model.find(data.id);

            return process.json({
                status: 'success',
                message,
                data
            });

        } catch (err) {
            return process.json({
                status: 'error',
                message: err.message
            }, 500);
        }
    }

}

module.exports = {{name}};
const BaseApiController = coreFile('controller.BaseApiController');
// const { supabase }   = coreFile('config.Database');
// const Validation     = coreFile('utils.Validation');
// const Model          = appFile('Models.Model'); 

class {{name}} extends BaseApiController {

    /**
     * [GET] List all resources
     */
    async index(process) {
        // 1. Guard: Auth 
        const user = this.auth(process);
        if (!user) return; 

        try {
            // 2. Fetch Data
            const items = await this.model.all(); 

            // 3. Response Success 
            return process.res.json({
                status: 'success',
                message: '{{name}} list retrieved successfully',
                data: items
            });

        } catch (err) {
            return BaseApiController.error(process.res, 'Internal server error', 500);
        }
    }
}

module.exports = {{name}};